generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum ProductStatus {
  AVAILABLE
  COMING_SOON
  DRAFT
}

enum OrderStatus {
  PENDING
  PAID
  PROCESSING
  SHIPPED
  DELIVERED
  CANCELLED
}

model Product {
  id               String        @id @default(cuid())
  slug             String        @unique
  name             String
  category         String
  priceCents       Int?
  stock            Int           @default(0)
  status           ProductStatus @default(DRAFT)
  shortDescription String
  description      String
  specsJson        String
  includedJson     String
  featuresJson      String        @default("[]")
  trustItemsJson    String        @default("[]")
  warranty         String?
  compatibility    String?
  rentals          Rental[]

  reservations     StockReservation[] 
  images           ProductImage[]
  orderItems       OrderItem[]

  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt
}

model ProductImage {
  id        String   @id @default(cuid())
  url       String
  alt       String?
  sortOrder Int      @default(0)

  productId String
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
}

model AdminUser {
  id           String   @id @default(cuid())
  email        String   @unique
  name         String
  passwordHash String
  role         String   @default("ADMIN")

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model CustomerUser {

  id                         String   @id @default(cuid())

  email                      String   @unique

  name                       String?

  passwordHash               String

  emailVerifiedAt            DateTime?

  emailVerificationToken     String?  @unique

  emailVerificationExpiresAt DateTime?

  orders                     Order[]

  createdAt                  DateTime @default(now())

  updatedAt                  DateTime @updatedAt

}

model Order {
  id                      String      @id @default(cuid())

  customerName            String
  customerEmail           String
  customerPhone           String?
  address                 String?
  city                    String?
  postalCode              String?
  country                 String?
  notes                   String?

  status                  OrderStatus @default(PENDING)
  totalCents              Int

  stripeCheckoutSessionId String?
  stripePaymentIntentId   String?   @unique

  paidAt                  DateTime?
  invoiceNumber           String?   @unique
  invoiceSentAt           DateTime?
  invoiceEmailId          String?

  customerUserId          String?
  customerUser            CustomerUser? @relation(fields: [customerUserId], references: [id], onDelete: SetNull)

  items                   OrderItem[]

  createdAt               DateTime    @default(now())
  updatedAt               DateTime    @updatedAt
}

model OrderItem {
  id         String  @id @default(cuid())

  quantity   Int
  unitCents  Int
  name       String

  orderId    String
  order      Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)

  productId  String?
  product    Product? @relation(fields: [productId], references: [id], onDelete: SetNull)
}

enum RentalStatus {
  PENDING    // pedido recebido, à espera de aprovação
  APPROVED   // aprovado pelo admin
  REJECTED   // rejeitado pelo admin
  CANCELLED  // cancelado
}

model Rental {
  id            String       @id @default(cuid())

  // Produto alugado
  productId     String
  product       Product      @relation(fields: [productId], references: [id], onDelete: Cascade)

  // Datas do aluguer
  startDate     DateTime
  endDate       DateTime

  // Dados do cliente
  customerName  String
  customerEmail String
  customerPhone String?

  // Valores (simulados — caução + total)
  depositCents  Int          @default(0)
  totalCents    Int          @default(0)

  // Estado
  status        RentalStatus @default(PENDING)

  // Notas
  notes         String?

  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  @@index([productId])
  @@index([status])
  @@index([startDate, endDate])
}


enum ReviewStatus {
  PENDING    // submetida pelo cliente, à espera de aprovação
  APPROVED   // aprovada pelo admin, visível no site
  REJECTED   // rejeitada
}

model Review {
  id          String       @id @default(cuid())

  customerName String
  rating       Int          // 1 a 5 estrelas
  title        String?
  body         String

  status       ReviewStatus @default(PENDING)

  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
}

model GalleryImage {
  id        String   @id @default(cuid())

  url       String
  alt       String?
  sortOrder Int      @default(0)

  createdAt DateTime @default(now())
}



enum ReservationStatus {
  WAITING    // à espera que haja stock
  NOTIFIED   // já foi avisado que há stock
  CANCELLED  // cancelada
}

model StockReservation {
  id            String            @id @default(cuid())

  productId     String
  product       Product           @relation(fields: [productId], references: [id], onDelete: Cascade)

  customerName  String
  customerEmail String

  status        ReservationStatus @default(WAITING)
  notifiedAt    DateTime?

  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt

  @@index([productId])
  @@index([status])
  @@unique([productId, customerEmail])  // evita reservas duplicadas do mesmo email
}
